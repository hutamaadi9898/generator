APP_NAME=Anime LoRA Lab
APP_HOST=127.0.0.1
APP_PORT=8000
APP_BASE_URL=http://127.0.0.1:8000
DATA_DIR=data
DATABASE_URL=sqlite:///./data/app.db

GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

RUNPOD_API_KEY=replace_me
RUNPOD_API_BASE=https://api.runpod.ai/v2
RUNPOD_GENERATE_ENDPOINT_ID=replace_me
RUNPOD_TRAIN_ENDPOINT_ID=replace_me
RUNPOD_SUBMISSION_MODE=plain
RUNPOD_GENERATE_FUNCTION_NAME=nova_generate
RUNPOD_TRAIN_FUNCTION_NAME=lora_train
RUNPOD_VOLUME_ROOT=/runpod-volume
RUNPOD_VOLUME_NAME=anime-lora-lab
RUNPOD_VOLUME_SIZE_GB=300
RUNPOD_DATA_CENTER=EU_RO_1

HF_TOKEN=
CIVITAI_API_TOKEN=
NOVA_MODEL_SOURCE=
NOVA_MODEL_SOURCE_MAP_JSON=
NOVA_MODEL_CACHE_DIR=/runpod-volume/models
NOVA_TORCH_DTYPE=float16
NOVA_CIVITAI_BASE_MODEL=Illustrious
SD_SCRIPTS_REPO=https://github.com/kohya-ss/sd-scripts.git
SD_SCRIPTS_REF=main

BASE_MODEL_REF=nova-anime-xl-illustrious

# Legacy Flash-only settings below.
# Optional: pin Flash away from Docker Hub `latest` for local Docker preview on
# machines whose NVIDIA driver cannot satisfy CUDA 12.8.
# FLASH_IMAGE_TAG=1.0.1
# Optional for Podman-backed local preview: avoid short-name resolution prompts.
# FLASH_GPU_IMAGE=docker.io/runpod/flash:1.0.1
# FLASH_CPU_IMAGE=docker.io/runpod/flash-cpu:1.0.1
# FLASH_LB_IMAGE=docker.io/runpod/flash-lb:1.0.1
# FLASH_CPU_LB_IMAGE=docker.io/runpod/flash-lb-cpu:1.0.1
# FLASH_BUILD_PYTHON_VERSION=3.12
